# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/relipa_quiz?schema=public"

# API server
PORT=4000

# Public base URL of THIS api (used to build QR/join links if no CLIENT_URL)
API_URL="http://localhost:4000"

# Where the Next.js frontend is served. Used for CORS and to build join/QR links.
CLIENT_URL="http://localhost:3000"
