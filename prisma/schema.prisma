// Relipa Quiz — data model
// A Quiz is a reusable TEMPLATE (questions + options).
// A GameSession is one LIVE run of a quiz that participants join.
// Participants and their Answers belong to a session, enabling per-run stats.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Quiz template
// ---------------------------------------------------------------------------

model Quiz {
  id          String        @id @default(uuid())
  title       String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  questions   Question[]
  sessions    GameSession[]
}

enum QuestionType {
  SINGLE // exactly one correct option
  MULTIPLE // more than one correct option; player must pick the exact set
}

model Question {
  id        String         @id @default(uuid())
  quiz      Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  quizId    String
  order     Int // 0-based position within the quiz
  text      String
  type      QuestionType   @default(SINGLE)
  timeLimit Int            @default(20) // seconds the question stays open
  points    Int            @default(1000) // max points awarded for a correct answer
  options   AnswerOption[]
  answers   Answer[]

  @@unique([quizId, order])
}

model AnswerOption {
  id         String     @id @default(uuid())
  question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId String
  order      Int // 0-based; maps to A/B/C/D on screen
  text       String
  isCorrect  Boolean    @default(false)
  answers    Answer[]

  @@unique([questionId, order])
}

// ---------------------------------------------------------------------------
// Live game run
// ---------------------------------------------------------------------------

enum SessionStatus {
  LOBBY // waiting for players to join
  IN_PROGRESS // a question is live or between questions
  FINISHED // all questions done
}

model GameSession {
  id           String        @id @default(uuid())
  quiz         Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  quizId       String
  joinCode     String        @unique // short human-typable code, also encoded in the QR link
  status       SessionStatus @default(LOBBY)
  currentIndex Int           @default(-1) // index of the question currently shown (-1 = not started)
  createdAt    DateTime      @default(now())
  startedAt    DateTime?
  endedAt      DateTime?
  participants Participant[]
  answers      Answer[]
}

model Participant {
  id        String      @id @default(uuid())
  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  nickname  String
  score     Int         @default(0)
  connected Boolean     @default(true)
  joinedAt  DateTime    @default(now())
  answers   Answer[]

  @@unique([sessionId, nickname]) // nicknames unique within a single game
}

model Answer {
  id            String        @id @default(uuid())
  session       GameSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId     String
  participant   Participant   @relation(fields: [participantId], references: [id], onDelete: Cascade)
  participantId String
  question      Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId    String
  option        AnswerOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)
  optionId      String? // the single chosen option for SINGLE questions (null for multi)
  selectedOptionIds String[] @default([]) // every option the player picked (1 for single, n for multiple)
  isCorrect     Boolean
  timeTakenMs   Int // how long after the question opened the answer arrived
  pointsAwarded Int
  answeredAt    DateTime      @default(now())

  @@unique([participantId, questionId]) // one answer per question per player
}
